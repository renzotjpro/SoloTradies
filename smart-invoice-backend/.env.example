# LLM Provider: openai (default), anthropic, deepseek
LLM_PROVIDER=openai
# LLM_MODEL=gpt-4o-mini          # Optional: override default model per provider

# API Keys (provide the one matching your LLM_PROVIDER)
OPENAI_API_KEY=sk-your-openai-api-key-here
# ANTHROPIC_API_KEY=sk-ant-your-anthropic-key-here
# DEEPSEEK_API_KEY=sk-your-deepseek-key-here

# Supabase PostgreSQL connection
SUPABASE_URL=https://your-project.supabase.co
SUPABASE_KEY=your-supabase-publishable-key

# Supabase JWT secret (from Dashboard > Settings > API > JWT Secret)
SUPABASE_JWT_SECRET=your-supabase-jwt-secret

# CORS (comma-separated origins, default: * for dev)
# CORS_ORIGINS=http://localhost:3000,https://yourdomain.com

# Server config
# PORT=8000
# LOG_LEVEL=info
# WEB_CONCURRENCY=1
